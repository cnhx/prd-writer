{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$(git rev-parse --show-toplevel)/scripts/update-skill.sh\" --auto",
            "timeout": 30,
            "statusMessage": "Updating prd-writer skill"
          }
        ]
      }
    ]
  }
}
